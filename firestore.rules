rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Items: anyone can read, only authenticated users can write
    match /items/{itemId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
    
    // Conversations: only buyer or seller can read/write
    match /conversations/{convId} {
      allow read, update, delete: if request.auth != null 
        && (request.auth.token.email == resource.data.buyerEmail 
            || request.auth.token.email == resource.data.sellerEmail);
      allow create: if request.auth != null 
        && request.auth.token.email == request.resource.data.buyerEmail;
    }
    
    // Messages subcollection: only participants can read/write
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /conversations/{convId}/messages/{msgId} {
      allow read, write: if request.auth != null 
        && (get(/databases/$(database)/documents/conversations/$(convId)).data.buyerEmail == request.auth.token.email 
            || get(/databases/$(database)/documents/conversations/$(convId)).data.sellerEmail == request.auth.token.email);
    }
  }
}
